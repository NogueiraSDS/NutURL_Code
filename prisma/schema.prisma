// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Link {
  id        String    @id @default(cuid())
  url       String
  slug      String    @unique
  clicks    Int       @default(0)
  hasAd     Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?
  userId    String?
  visits    Visit[]
}

model Visit {
  id        String   @id @default(cuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id])
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())
}

model User {
  id                 String   @id @default(cuid())
  firebaseUid        String   @unique
  stripeCustomerId   String?  @unique
  email              String?
  tier               String   @default("free") // "free", "pro" ou "premium"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  profile            Profile?
}

model Profile {
  id              String        @id @default(cuid())
  username        String        @unique // O nome de usuário na URL (ex: @joao)
  title           String?       // Nome que aparece no topo da página
  bio             String?       // Pequena descrição
  avatarUrl       String?
  coverUrl        String?
  backgroundColor String?       @default("#0f172a") // Cor de fundo do perfil
  theme           String?       @default("solid") // Temas premium: solid, gradient_1, gradient_2, matrix
  hideWatermark   Boolean       @default(false)
  userId          String        @unique // Ligação com o User existente
  user            User          @relation(fields: [userId], references: [id])
  links           ProfileLink[]
  visits          ProfileVisit[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ProfileLink {
  id              String   @id @default(cuid())
  profileId       String
  profile         Profile  @relation(fields: [profileId], references: [id])
  title           String
  url             String
  icon            String   @default("web") // Identificador do ícone (ex: instagram, web)
  isActive        Boolean  @default(true)
  isAgeRestricted Boolean  @default(false)
  isSocialIcon    Boolean  @default(false)
  hasAd           Boolean  @default(true) // Controle de monetização individual
  clicks          Int      @default(0)
  order           Int      @default(0) // Ordem de exibição dos links
  animation       String?  @default("none") // Animação premium: none, pulse, bounce, wiggle
  groupName       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProfileVisit {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())
}

